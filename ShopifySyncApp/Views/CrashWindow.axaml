<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShopifySyncApp.Views.CrashWindow"
        Title="Unhandled Error"
        Width="560" Height="360"
        WindowStartupLocation="CenterScreen"
        CanResize="True">
  <DockPanel Margin="20">
    <Border DockPanel.Dock="Top" Background="#fde7e9" BorderBrush="#c42b1c"
            BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
      <TextBlock Text="An unexpected error occurred. The application will close."
                 FontWeight="SemiBold" FontSize="13" Foreground="#c42b1c" TextWrapping="Wrap" />
    </Border>
    <ScrollViewer>
      <TextBox Name="ErrorText" IsReadOnly="True" TextWrapping="Wrap"
               AcceptsReturn="True" FontFamily="Consolas,Monospace" FontSize="12" />
    </ScrollViewer>
  </DockPanel>
</Window>
