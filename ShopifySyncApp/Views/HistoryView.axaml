<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ShopifySyncApp.Views.HistoryView">

  <ScrollViewer Padding="20 24">
    <StackPanel Spacing="16">

      <!-- Run selector -->
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="Sync run:" FontSize="13" Foreground="#555555"
                   VerticalAlignment="Center" />
        <ComboBox ItemsSource="{Binding DisplayFileNames}"
                  SelectedItem="{Binding SelectedDisplayName}"
                  MinWidth="260" />
      </StackPanel>

      <!-- Selected run details card -->
      <Border Background="White" BorderBrush="#dddddd" BorderThickness="1"
              CornerRadius="4" Padding="14"
              IsVisible="{Binding SelectedRecord, Converter={x:Static ObjectConverters.IsNotNull}}">
        <StackPanel Spacing="6">
          <TextBlock FontSize="13">
            <Run Text="Completed: " />
            <Run Text="{Binding SelectedRecord.CompletedAt, StringFormat='{}{0:MMMM d, yyyy, h:mm tt}'}" />
          </TextBlock>

          <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
            <TextBlock Text="Total PCA items" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding SelectedRecord.TotalPcaItems}" FontSize="13" FontWeight="SemiBold" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Changed" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding SelectedRecord.ChangedItems}" FontSize="13" FontWeight="SemiBold" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Pushed to Shopify" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding SelectedRecord.PushedToShopify}" FontSize="13" FontWeight="SemiBold" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Not in sync map" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding SelectedRecord.NotInSyncMapCount}" FontSize="13" FontWeight="SemiBold" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Errors" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding SelectedRecord.Errors.Count}" FontSize="13" FontWeight="SemiBold" />
          </Grid>

          <!-- Fatal error banner -->
          <Border Background="#fde7e9" BorderBrush="#c42b1c" BorderThickness="1"
                  CornerRadius="4" Padding="10" Margin="0,6,0,0"
                  IsVisible="{Binding SelectedRecord.FatalError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding SelectedRecord.FatalError}" Foreground="#c42b1c"
                       FontSize="12" TextWrapping="Wrap" />
          </Border>

          <!-- Error groups -->
          <ItemsControl ItemsSource="{Binding SelectedRecordErrors}" Margin="0,4,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,6,0,0">
                  <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold"
                             FontSize="12" Foreground="#c42b1c" />
                  <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12" Foreground="#666666"
                                   Margin="12,1,0,0" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Placeholder when nothing selected -->
      <TextBlock Text="Select a run from the dropdown to view its details."
                 IsVisible="{Binding SelectedRecord, Converter={x:Static ObjectConverters.IsNull}}"
                 Foreground="#aaaaaa" FontSize="13" FontStyle="Italic" />

    </StackPanel>
  </ScrollViewer>
</UserControl>
