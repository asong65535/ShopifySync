<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ShopifySyncApp.ViewModels"
             x:Class="ShopifySyncApp.Views.SyncStatusView">

  <ScrollViewer Padding="20 24">
    <StackPanel Name="RootPanel" Spacing="16">

      <!-- Fatal error banner -->
      <Border Background="#fde7e9" BorderBrush="#c42b1c" BorderThickness="1"
              CornerRadius="4" Padding="12"
              IsVisible="{Binding FatalError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <StackPanel Spacing="4">
          <TextBlock Text="Sync completed with errors" FontWeight="SemiBold"
                     FontSize="13" Foreground="#c42b1c" />
          <TextBlock Text="{Binding FatalError}" FontSize="12" Foreground="#6e0000"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Progress bar (running only) -->
      <ProgressBar IsIndeterminate="{Binding IsRunning}"
                   IsVisible="{Binding IsRunning}"
                   Height="4" />

      <!-- Status row: dot + text -->
      <StackPanel Orientation="Horizontal" Spacing="10">
        <!-- Grey dot: never synced + idle -->
        <Ellipse Width="10" Height="10" Fill="#999999"
                 VerticalAlignment="Center">
          <Ellipse.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="!IsRunning" />
              <Binding Path="!HasSynced" />
            </MultiBinding>
          </Ellipse.IsVisible>
        </Ellipse>
        <!-- Green dot: idle + synced + no errors -->
        <Ellipse Width="10" Height="10" Fill="#4caf50"
                 VerticalAlignment="Center">
          <Ellipse.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="!IsRunning" />
              <Binding Path="HasSynced" />
              <Binding Path="!HasErrors" />
            </MultiBinding>
          </Ellipse.IsVisible>
        </Ellipse>
        <!-- Red dot: idle + synced + errors -->
        <Ellipse Width="10" Height="10" Fill="#c42b1c"
                 VerticalAlignment="Center">
          <Ellipse.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="!IsRunning" />
              <Binding Path="HasSynced" />
              <Binding Path="HasErrors" />
            </MultiBinding>
          </Ellipse.IsVisible>
        </Ellipse>
        <!-- Yellow dot: running -->
        <Ellipse Width="10" Height="10" Fill="#e5a000"
                 VerticalAlignment="Center"
                 IsVisible="{Binding IsRunning}" />

        <TextBlock Text="Syncing..." IsVisible="{Binding IsRunning}"
                   FontSize="14" VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="6"
                    IsVisible="{Binding !IsRunning}">
          <TextBlock Text="Unsynced" FontSize="14" VerticalAlignment="Center"
                     IsVisible="{Binding !HasSynced}" />
          <TextBlock Text="Idle" FontSize="14" VerticalAlignment="Center">
            <TextBlock.IsVisible>
              <MultiBinding Converter="{x:Static BoolConverters.And}">
                <Binding Path="HasSynced" />
                <Binding Path="!HasErrors" />
              </MultiBinding>
            </TextBlock.IsVisible>
          </TextBlock>
          <TextBlock Text="Completed with errors" FontSize="14" VerticalAlignment="Center"
                     Foreground="#c42b1c">
            <TextBlock.IsVisible>
              <MultiBinding Converter="{x:Static BoolConverters.And}">
                <Binding Path="HasSynced" />
                <Binding Path="HasErrors" />
              </MultiBinding>
            </TextBlock.IsVisible>
          </TextBlock>
          <TextBlock FontSize="12" Foreground="#888888" VerticalAlignment="Center"
                     IsVisible="{Binding LastCompletedAt, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Run Text="Last sync: " />
            <Run Text="{Binding LastCompletedAt, StringFormat='{}{0:MMM d, h:mm tt}'}" />
          </TextBlock>
        </StackPanel>
      </StackPanel>

      <!-- Sync Now button -->
      <Button Command="{Binding SyncNowCommand}"
              IsEnabled="{Binding !IsRunning}"
              Classes="accent"
              Padding="12 8">
        Sync Now
      </Button>

      <!-- Expander: last sync details -->
      <Expander Header="Last sync details"
                IsVisible="{Binding LastCompletedAt, Converter={x:Static ObjectConverters.IsNotNull}}"
                Padding="4">
        <StackPanel Spacing="2" Margin="4,8,4,4">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Total PCA items" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding TotalPcaItems}" FontSize="13" FontWeight="SemiBold" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Changed" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding ChangedItems}" FontSize="13" FontWeight="SemiBold" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Pushed to Shopify" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding PushedToShopify}" FontSize="13" FontWeight="SemiBold" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Not in sync map" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding NotInSyncMapCount}" FontSize="13" FontWeight="SemiBold" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Errors" FontSize="13" Foreground="#555555" />
            <TextBlock Grid.Column="1" Text="{Binding ErrorCount}" FontSize="13" FontWeight="SemiBold" />
          </Grid>

          <!-- Error groups inside expander -->
          <ItemsControl ItemsSource="{Binding ErrorGroups}" Margin="0,8,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,6,0,0">
                  <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold"
                             FontSize="12" Foreground="#c42b1c" />
                  <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12" Foreground="#666666"
                                   Margin="12,1,0,0" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Expander>

    </StackPanel>
  </ScrollViewer>
</UserControl>
